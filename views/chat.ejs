<!DOCTYPE html>
<html>
<head>
  <title>Chat</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .user-item { display: flex; align-items: center; padding: 12px; background: #f9f9fc; border-radius: 12px; margin-bottom: 10px; cursor: pointer; border: 2px solid #eee; transition: 0.2s; text-decoration: none; }
    .user-item:hover { border-color: #2575fc; background: #eef2ff; }
    .user-avatar { width: 45px; height: 45px; border-radius: 50%; background: linear-gradient(135deg,#6a11cb,#2575fc); display: flex; align-items: center; justify-content: center; font-size: 20px; margin-right: 12px; flex-shrink: 0; }
    .online-dot { width: 10px; height: 10px; background: #28a745; border-radius: 50%; margin-left: auto; }
    .offline-dot { width: 10px; height: 10px; background: #ccc; border-radius: 50%; margin-left: auto; }
  </style>
</head>
<body>
<div class="container">
  <a href="/">← Home</a>
  <h1>💬 Messages</h1>
  <% allUsers.forEach(u => { %>
  <a href="/chat/<%= u.username %>" class="user-item">
    <% if (u.avatar) { %>
      <img src="<%= u.avatar %>" style="width:45px;height:45px;border-radius:50%;object-fit:cover;margin-right:12px">
    <% } else { %>
      <div class="user-avatar">👤</div>
    <% } %>
    <span style="font-weight:600"><%= u.username %></span>
    <span class="offline-dot online-indicator" data-user="<%= u.username %>"></span>
  </a>
  <% }) %>
</div>
<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.emit('userOnline', '<%= user %>');
socket.on('onlineUsers', (users) => {
  document.querySelectorAll('.online-indicator').forEach(el => {
    const u = el.dataset.user;
    el.className = users.includes(u) ? 'online-dot online-indicator' : 'offline-dot online-indicator';
  });
});
</script>
</body>
</html>
