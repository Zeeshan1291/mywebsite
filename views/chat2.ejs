cat > views/call.ejs << 'EOF'
<!DOCTYPE html>
<html>
<head>
  <title><%= type === 'video' ? 'Video' : 'Voice' %> Call</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { background: #1a1a2e; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .call-box { text-align: center; color: white; }
    .avatar-big { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(90deg, #6a11cb, #2575fc); display: flex; align-items: center; justify-content: center; font-size: 42px; font-weight: bold; color: white; margin: 0 auto 20px; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(106,17,203,0.5); } 50% { box-shadow: 0 0 0 20px rgba(106,17,203,0); } }
    .status { font-size: 16px; opacity: 0.8; margin-bottom: 30px; }
    .call-btns { display: flex; gap: 20px; justify-content: center; margin-top: 20px; }
    .btn-call { width: 60px; height: 60px; border-radius: 50%; border: none; font-size: 24px; cursor: pointer; }
    .btn-end { background: red; }
    .btn-mute { background: #555; }
    video { width: 100%; max-width: 350px; border-radius: 12px; background: #000; }
    #localVid { position: fixed; bottom: 100px; right: 20px; width: 100px; border-radius: 12px; }
  </style>
</head>
<body>
<div class="call-box">
  <% if (type === 'video') { %>
    <video id="remoteVid" autoplay playsinline></video>
    <video id="localVid" autoplay muted playsinline></video>
  <% } %>
  <div class="avatar-big"><%= other[0].toUpperCase() %></div>
  <h2 style="color:white">@<%= other %></h2>
  <p class="status" id="status">Calling... 📞</p>
  <div class="call-btns">
    <button class="btn-call btn-mute" onclick="toggleMute()">🎤</button>
    <button class="btn-call btn-end" onclick="endCall()">📵</button>
    <% if (type === 'video') { %>
      <button class="btn-call btn-mute" onclick="toggleCam()">📷</button>
    <% } %>
  </div>
</div>
<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
const me = '<%= user %>';
const other = '<%= other %>';
const type = '<%= type %>';
const room = [me, other].sort().join('_call_');
socket.emit('join-call', room);

let pc, localStream, muted = false, camOff = false;

async function startCall() {
  localStream = await navigator.mediaDevices.getUserMedia({ video: type === 'video', audio: true });
  if (type === 'video') document.getElementById('localVid').srcObject = localStream;
  pc = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });
  localStream.getTracks().forEach(t => pc.addTrack(t, localStream));
  pc.ontrack = e => { if (type === 'video') document.getElementById('remoteVid').srcObject = e.streams[0]; };
  pc.onicecandidate = e => { if (e.candidate) socket.emit('call-signal', { room, type: 'candidate', candidate: e.candidate }); };
  const offer = await pc.createOffer();
  await pc.setLocalDescription(offer);
  socket.emit('call-signal', { room, type: 'offer', sdp: offer });
  document.getElementById('status').textContent = 'Ringing... 🔔';
}

socket.on('call-signal', async data => {
  if (data.type === 'offer') {
    pc = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });
    localStream = await navigator.mediaDevices.getUserMedia({ video: type === 'video', audio: true });
    if (type === 'video') document.getElementById('localVid').srcObject = localStream;
    localStream.getTracks().forEach(t => pc.addTrack(t, localStream));
    pc.ontrack = e => { if (type === 'video') document.getElementById('remoteVid').srcObject = e.streams[0]; };
    pc.onicecandidate = e => { if (e.candidate) socket.emit('call-signal', { room, type: 'candidate', candidate: e.candidate }); };
    await pc.setRemoteDescription(data.sdp);
    const answer = await pc.createAnswer();
    await pc.setLocalDescription(answer);
    socket.emit('call-signal', { room, type: 'answer', sdp: answer });
    document.getElementById('status').textContent = 'Connected ✅';
  } else if (data.type === 'answer') {
    await pc.setRemoteDescription(data.sdp);
    document.getElementById('status').textContent = 'Connected ✅';
  } else if (data.type === 'candidate') {
    await pc.addIceCandidate(data.candidate);
  }
});

socket.on('call-end', () => { alert('Call khatam ho gayi!'); window.location = '/messages/' + other; });

function endCall() { socket.emit('call-end', { room }); if (localStream) localStream.getTracks().forEach(t => t.stop()); window.location = '/messages/' + other; }
function toggleMute() { muted = !muted; localStream.getAudioTracks().forEach(t => t.enabled = !muted); }
function toggleCam() { camOff = !camOff; localStream.getVideoTracks().forEach(t => t.enabled = !camOff); }

startCall();
</script>
</body>
</html>
