<!DOCTYPE html>
<html>
<head>
  <title>Chat</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { padding: 0; }
    .chat-header { background: linear-gradient(90deg, #6a11cb, #2575fc); padding: 15px 20px; display: flex; align-items: center; justify-content: space-between; border-radius: 0; position: fixed; top: 0; width: 100%; z-index: 99; }
    .chat-header h3 { color: white; margin: 0; }
    .call-btns a { color: white; font-size: 22px; margin-left: 15px; text-decoration: none; }
    .chat-body { margin-top: 70px; margin-bottom: 70px; padding: 15px; overflow-y: auto; height: calc(100vh - 140px); }
    .bubble { max-width: 75%; padding: 10px 15px; border-radius: 18px; margin: 6px 0; word-wrap: break-word; font-size: 14px; }
    .bubble.me { background: linear-gradient(90deg, #6a11cb, #2575fc); color: white; margin-left: auto; border-bottom-right-radius: 4px; }
    .bubble.them { background: #f0f0f0; color: #333; border-bottom-left-radius: 4px; }
    .time { font-size: 10px; opacity: 0.6; margin-top: 3px; }
    .chat-footer { position: fixed; bottom: 0; width: 100%; background: white; padding: 10px 15px; display: flex; gap: 10px; border-top: 1px solid #eee; }
    .chat-footer input { flex: 1; margin: 0; border-radius: 25px; padding: 12px 18px; }
    .chat-footer button { width: auto; padding: 12px 20px; border-radius: 25px; }
  </style>
</head>
<body>
<div class="chat-header">
  <div style="display:flex;align-items:center;gap:12px">
    <a href="/messages" style="color:white;font-size:20px">←</a>
    <div style="width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;color:white;font-weight:bold"><%= other[0].toUpperCase() %></div>
    <h3>@<%= other %></h3>
  </div>
  <div class="call-btns">
    <a href="/call/<%= other %>" title="Voice Call">📞</a>
    <a href="/videocall/<%= other %>" title="Video Call">🎥</a>
  </div>
</div>

<div class="chat-body" id="chatBody">
  <% convo.forEach(m => { %>
    <div style="display:flex;flex-direction:column;align-items:<%= m.from === me ? 'flex-end' : 'flex-start' %>">
      <div class="bubble <%= m.from === me ? 'me' : 'them' %>">
        <%= m.text %>
        <div class="time"><%= m.time %></div>
      </div>
    </div>
  <% }) %>
</div>

<div class="chat-footer">
  <input type="text" id="msgInput" placeholder="Message..." onkeypress="if(event.key==='Enter') sendMsg()">
  <button onclick="sendMsg()">➤</button>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
const room = ['<%= me %>', '<%= other %>'].sort().join('_');
socket.emit('join-live', room);
document.getElementById('chatBody').scrollTop = 999999;

socket.on('live-message', data => {
  const body = document.getElementById('chatBody');
  const align = data.user === '<%= me %>' ? 'flex-end' : 'flex-start';
  const cls = data.user === '<%= me %>' ? 'me' : 'them';
  body.innerHTML += '<div style="display:flex;flex-direction:column;align-items:' + align + '"><div class="bubble ' + cls + '">' + data.text + '<div class="time">Just now</div></div></div>';
  body.scrollTop = 999999;
});

