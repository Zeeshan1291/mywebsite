<!DOCTYPE html>
<html>
<head>
  <title>Story</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#000; min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .story-box { position:relative; width:100%; max-width:400px; min-height:100vh; background:linear-gradient(135deg,#6a11cb,#2575fc); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:30px 20px; }
    .story-bar { position:absolute; top:0; left:0; right:0; height:4px; background:rgba(255,255,255,0.3); }
    .story-bar-fill { height:100%; background:white; animation:progress 5s linear forwards; }
    @keyframes progress { from{width:0} to{width:100%} }
    .story-user { position:absolute; top:20px; left:20px; color:white; font-weight:700; font-size:16px; }
    .story-img { width:100%; border-radius:16px; max-height:60vh; object-fit:cover; }
    .story-text { color:white; font-size:22px; font-weight:700; text-align:center; text-shadow:0 2px 10px rgba(0,0,0,0.5); margin-top:20px; }
    .views { position:absolute; bottom:60px; color:rgba(255,255,255,0.8); font-size:13px; }
    .back-btn { position:absolute; bottom:20px; color:white; text-decoration:none; background:rgba(255,255,255,0.2); padding:10px 20px; border-radius:20px; }
  </style>
</head>
<body>
<div class="story-box">
  <div class="story-bar"><div class="story-bar-fill"></div></div>
  <div class="story-user">👤 <%= story.user %></div>
  <% if (story.image) { %>
    <img src="<%= story.image %>" class="story-img">
  <% } %>
  <% if (story.text) { %>
    <div class="story-text"><%= story.text %></div>
  <% } %>
  <div class="views">👁️ <%= story.views.length %> views</div>
  <a href="/posts" class="back-btn">← Back</a>
</div>
<script>
setTimeout(() => window.location.href = '/posts', 5000);
</script>
</body>
</html>
