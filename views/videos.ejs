<!DOCTYPE html>
<html>
<head>
  <title>Videos</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    video { width: 100%; border-radius: 12px; margin: 10px 0; }
    .upload-box { background: #f9f9fc; border-radius: 16px; padding: 20px; margin-bottom: 20px; border: 2px dashed #2575fc; }
  </style>
</head>
<body>
<div class="container">
  <h1>🎥 Videos</h1>
  <a href="/">← Back</a>
  <br><br>
  <div class="upload-box">
    <h3>📤 Video Upload Karo</h3>
    <form method="POST" action="/videos/upload" enctype="multipart/form-data">
      <label>Title</label>
      <input type="text" name="title" placeholder="Video ka title" required>
      <label>Description</label>
      <input type="text" name="description" placeholder="Video ke baare mein">
      <label>Video File (Max 50MB)</label>
      <input type="file" name="video" accept="video/*" required>
      <button type="submit">🎬 Upload</button>
    </form>
  </div>
  <% videos.slice().reverse().forEach(v => { %>
    <div class="post">
      <div class="post-user">@<%= v.user %></div>
      <h3><%= v.title %></h3>
      <p class="post-content"><%= v.description %></p>
      <video controls>
        <source src="/videos/<%= v.filename %>" type="video/mp4">
      </video>
      <small><%= v.time %></small>
      <br>
      <form method="POST" action="/videos/<%= v.id %>/like" style="display:inline">
        <button class="like-btn" type="submit">❤️ <%= v.likes.length %></button>
      </form>
    </div>
  <% }) %>
</div>
</body>
</html>
